<!-- Main  Footer -->
    <footer class="main-footer">
    {% block footer %}
   
        <div class="footer-top">
            <div class="auto-container">
                <div class="row align-items-center">
                    <div class="col-lg-3">
                        <div class="logo">
                         {% set account = webspaceSettings.content.account.entity|default %}

                                

                        
    {% if account is defined and account.logo is defined %}
    {% set logo = sulu_resolve_media(account.logo.id, app.request.locale) %}
    <a href="{{ sulu_content_root_path() }}" title="{{ account.name }}" rel="home">
        <img src="{{ logo.thumbnails['153x'] }}" 
             alt="{{ logo.title }}" 
             title="{{ logo.description|default(logo.title) }}">
    </a>
{% else %}
    <a href="{{ sulu_content_root_path() }}" rel="home"><img src="/assets/default-logo.png" alt="Default Logo">
    </a>
{% endif %}
                        
                        </div>
                    </div>
                    <div class="col-lg-9">
                        <div class="wrapper-box">
                            <h4>Signup For Newsletter</h4>
                            <div class="newsletter-form">
                                <form class="ajax-sub-form" method="post">
                                    <div class="form-group">
                                        <input type="email" placeholder="Email Address..." id="subscription-email">
                                        <button type="submit" class="theme-btn"><i class="icon-arrow"></i><span></span></button>
                                        <label class="subscription-label" for="subscription-email"></label>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="auto-container">
            <!--Widgets Section-->
            <div class="widgets-section">
                <div class="row clearfix">
                    
                    <!--Column-->
                    <div class="column col-lg-3 col-md-6">
                        <div class="widget about-widget">
                            <h3 class="widget-title">About Us</h3>
                            <div class="text">
                            </div>
                            <ul class="social-links">
                                <li><a href="#"><i class="fab fa-instagram"></i></a></li>
                            </ul>
                        </div>
                    </div>
                    
                    <!--Column-->
                    <div class="column col-lg-3 col-md-6">
                        <div class="widget links-widget">
                            <h3 class="widget-title">Services</h3>
                            <div class="widget-content">
                                
                            </div>
                        </div>
                    </div>

                    <!--Column-->
                    <div class="column col-lg-3 col-md-6">
                        <div class="widget links-widget">
                            <h3 class="widget-title">{{ 'quick_links'|trans }}</h3>
                            <div class="widget-content">
                                <ul id="menu-footer-quick-link" class="menu">					
									{% for item in sulu_navigation_root_tree('footer', 2) %}
                                     {% set itemUrl = sulu_content_path(item.url) %}
										<li><a href="{{ itemUrl }}">{{ item.title }}</a>
										{% if item.children|length > 0 %}
						                  <ul>
                                        {% for child in item.children %}
                                        {% set childUrl = sulu_content_path(item.url) %}
                                            <li class=""><a href="{{ childUrl }}">{{ child.title }}</a></li>
                                        {% endfor %}
                                             </ul>
                                        {% endif %} 
					                {% endfor %}
										</li>							
									</ul>                                
                            </div>
                        </div>
                    </div>
                    
                    <!--Column-->
                    <div class="column col-lg-3 col-md-6">
                        <div class="widget contact-widget">
                            <h3 class="widget-title">{% trans %}Contact Us{% endtrans %}</h3>
                            <div class="widget-content">
                            {% if account %}
                            {% set address = account.accountAddresses[0].address %}
                                <ul class="contact-info">
                                    <li>
                                        <div class="icon"> <i class="icon-placeholder"></i></div>
                                        <div class="text">
                                        
                                        <strong>{% trans %}Visit Our Office{% endtrans %}</strong> 
                                       
                                        {{ address.street ~ ' ' ~ address.number }}, <br> 
                                            {{ address.zip ~ ' ' ~ address.city }},
                                            {{ country(address.countryCode) }}
                                        
                                        </div>
                                    </li>
                                    <li>
                                        <div class="icon"><i class="icon-phone"></i></div>
                                        <div class="text">
                                            <strong>{% trans %}Phone No{% endtrans %}.</strong>
                                            <a href="tel:{{ account.mainPhone|replace({' ':''}) }}">{{ account.mainPhone }}</a>
                                        </div>
                                    </li>
                                    <li>
                                        <div class="icon"><i class="icon-envelope"></i></div>
                                        <div class="text">
                                            <strong>{% trans %}Email{% endtrans %}</strong>
                                            <a href="mailto:{{ account.mainEmail }}">{{ account.mainEmail }}</a>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
        <!-- Footer Bottom -->
        <div class="footer-bottom">
            <div class="auto-container">
                <div class="wrapper-box">
                    <div class="copyright">
                        <div class="text">

                        <p><span>{% trans %}Copyright{% endtrans %} © {{ 'now'|date('Y') }} {{ account.name }} {% trans %}All Rights Reserved {% endtrans %}</p></span>
                             <p>{% trans %}Managed by{% endtrans %} <a style="color:#e99323 !important;" href="https://bwengainc.net/" target="_blank">Bwenga Inc</a></p>
                        
                        
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
         {% endblock %}
    </footer>