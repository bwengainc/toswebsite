<!--Popular Posts Widget-->
<div class="widget widget_popular_post">
    <h3 class="widget-title">{% trans %}Recent Posts{% endtrans %}</h3>

    {% for post in recentPosts %}
        {% set trans = post.translations[app.request.locale] ?? post.translations|first %}

        <article class="post">
            <figure class="post-thumb">
                <a href="{{ sulu_content_path(trans.routePath) }}">
                    {% if post.image %}
                        <img src="{{ post.image.url }}" alt="{{ trans.title }}" style="width: 80px; height: 80px; object-fit: cover;">
                    {% endif %}
                </a>
            </figure>

            <div class="content">
                <h5>
                    <a href="{{ sulu_content_path(trans.routePath) }}">
                        {{ trans.title|length > 45 ? trans.title|slice(0, 45) ~ '...' : trans.title }}
                    </a>
                </h5>
                <div class="post-info" style="font-size: 12px; color: #888;">
                    <i class="far fa-calendar-alt"></i> 
                    {{ trans.authored|date("M d, Y") }}
                </div>
            </div>
        </article>
    {% else %}
        <p style="font-size: 13px; color: #999; font-style: italic; padding-left: 20px;">
            {% trans %}No popular posts available.{% endtrans %}
        </p>
    {% endfor %}
</div>


