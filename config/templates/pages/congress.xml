<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns:xi="http://www.w3.org/2001/XInclude"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>congress</key>

    <view>pages/congress</view>
    <controller>App\Controller\PageController::congressPage</controller>
    <cacheLifetime>86400</cacheLifetime>

    <meta>
        <title lang="en">Congress</title>
        <title lang="de">Congress</title>
    </meta>

    <properties>
          <property name="title" type="text_line" mandatory="true">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
            <params>
                <param name="headline" value="true"/>
            </params>

            <tag name="sulu.rlp.part"/>
        </property>

        <property name="url" type="resource_locator" mandatory="true">
            <meta>
                <title lang="en">Resourcelocator</title>
                <title lang="de">Adresse</title>
            </meta>

            <tag name="sulu.rlp"/>
        </property>
        <!-- HEADER SECTION -->
        <section name="header">
            <meta><title lang="en">Header</title></meta>
            <properties>
                <property name="tracking" type="text_area"><meta><title lang="en">Tracking</title></meta></property>
                <property name="sponsorLogo" type="media_selection" maxOccurs="1">
                    <meta><title lang="en">Sponsor Logo</title></meta>
                    <params><param name="types" value="image"/></params>
                </property>
                <property name="town" type="text_line"><meta><title lang="en">Town</title></meta></property>
                <property name="date" type="date"><meta><title lang="en">Date</title></meta></property>
                <property name="eventLink" type="url"><meta><title>Event link</title></meta></property>
                <property name="description" type="text_area"><meta><title lang="en">Description</title></meta></property>
                <property name="eventheaderimage" type="media_selection" maxOccurs="1">
                    <meta><title lang="en">Event header image</title></meta>
                    <params><param name="types" value="image"/></params>
                </property>
            </properties>
        </section>

        <!-- SPEAKER SECTION -->
        <section name="speaker">
            <meta><title lang="en">Speaker</title></meta>
            <properties>
                <property name="speakerHeadline" type="text_line"><meta><title lang="en">Headline</title></meta></property>
                <property name="speakerSubline" type="text_editor"><meta><title lang="en">Subline</title></meta></property>
                <block name="speakerItem" default-type="speaker" minOccurs="0">
                    <meta><title lang="en">Speaker item</title></meta>
                    <types>
                        <type name="speaker">
                            <meta><title lang="en">Speaker</title></meta>
                            <properties>
                                <property name="speakerItemImage" type="media_selection" maxOccurs="1">
                                    <meta><title lang="en">Profile image</title></meta>
                                    <params><param name="types" value="image"/></params>
                                </property>
                                <property name="speakerItemName" type="text_line"><meta><title lang="en">Name</title></meta></property>
                                <property name="speakerItemJobTitle" type="text_line"><meta><title lang="en">Job title</title></meta></property>
                                <property name="speakerItemCompany" type="text_line"><meta><title lang="en">Company</title></meta></property>
                                <property name="speakerItemBio" type="text_editor"><meta><title lang="en">Bio</title></meta></property>
                            </properties>
                        </type>
                    </types>
                </block>
            </properties>
        </section>

        <!-- COUNTER SECTION -->
        <section name="counter">
            <meta><title lang="en">Counter</title></meta>
            <properties>
                <property name="counterSpeaker" type="text_line"><meta><title lang="en">Speaker</title></meta></property>
                <property name="counterMember" type="text_line"><meta><title lang="en">Member</title></meta></property>
                <property name="counterHours" type="text_line"><meta><title lang="en">Hours</title></meta></property>
            </properties>
        </section>

        <!-- OVERVIEW SECTION -->
        <section name="overview">
            <meta><title lang="en">Overview</title></meta>
            <properties>
                <property name="overviewHeadline" type="text_line"><meta><title lang="en">Overview Headline</title></meta></property>
                <property name="overviewLeft" type="text_area"><meta><title lang="en">Overview left</title></meta></property>
                <property name="overviewRight" type="text_editor"><meta><title lang="en">Overview right</title></meta></property>
            </properties>
        </section>

        <!-- TIMETABLE SECTION -->
        <section name="timetable">
            <meta><title lang="en">Timetable</title></meta>
            <properties>
                <property name="timeTableHeadline" type="text_line"><meta><title lang="en">Headline</title></meta></property>
                <block name="timeTableItems" default-type="editor_image" minOccurs="0">
                    <meta><title lang="en">Time table</title></meta>
                    <types>
                        <type name="editor_image">
                            <meta><title lang="en">Time item</title></meta>
                            <properties>
                                <property name="time" type="time"><meta><title lang="en">Time</title></meta></property>
                                <property name="timetableHeadline" type="text_line"><meta><title lang="en">Headline</title></meta></property>
                                <property name="timetableDescription" type="text_editor"><meta><title lang="en">Description</title></meta></property>
                            </properties>
                        </type>
                    </types>
                </block>
            </properties>
        </section>

        <!-- CONTACT SECTION -->
        <section name="contact">
            <meta><title lang="en">Contact</title></meta>
            <properties>
                <property name="contactHeadline" type="text_line"><meta><title lang="en">Headline</title></meta></property>
                <property name="contactBodytext" type="text_editor"><meta><title lang="en">Bodytext</title></meta></property>
            </properties>
        </section>

        <!-- PRICE SECTION -->
        <section name="price">
            <meta><title lang="en">Price</title></meta>
            <properties>
                <property name="priceHeadline" type="text_line"><meta><title lang="en">Headline</title></meta></property>
                <property name="priceBodytext" type="text_area"><meta><title lang="en">Bodytext</title></meta></property>
            </properties>
        </section>

        <!-- HIGHLIGHTS SECTION -->
              <section name="highlights">
            <meta>
                <title lang="en">Highlights</title>
            </meta>
            <properties>
                <property name="highlightsHeadline" type="text_line" colspan="6">
                    <meta>
                        <title lang="en">Headline</title>
                    </meta>
                </property>
                <property name="highlightsSubline" type="text_line" colspan="6">
                    <meta>
                        <title lang="en">Subline</title>
                    </meta>
                </property>
                <block name="highlightsItemsBlock" default-type="highlightsItems" minOccurs="0">
                    <meta>
                        <title lang="en">Highlight</title>
                    </meta>
                    <types>
                        <type name="highlightsItems">
                            <meta>
                                <title lang="en"></title>
                            </meta>
                            <properties>
                                <property name="highlightsItemImage" type="media_selection" maxOccurs="1">
                                    <meta>
                                        <title lang="en">Image</title>
                                    </meta>
                                    <params>
                                        <param name="types" value="image"/>
                                    </params>
                                </property>
                                <property name="highlightsItemHeadline" type="text_line" colspan="4">
                                    <meta>
                                        <title lang="en">Headline</title>
                                    </meta>
                                </property>
                                <property name="highlightsItemStars" type="single_select" colspan="4">
                                    <meta>
                                        <title lang="en">Stars</title>
                                    </meta>
                                    <params>
                                        <param name="default_value" value="5"/>
                                        <param name="values" type="collection">
                                            <param name="five">
                                                <meta>
                                                    <title lang="en">5</title>
                                                </meta>
                                            </param>
                                            <param name="four">
                                                <meta>
                                                    <title lang="en">4</title>
                                                </meta>
                                            </param>
                                            <param name="three">
                                                <meta>
                                                    <title lang="en">3</title>
                                                </meta>
                                            </param>
                                            <param name="two">
                                                <meta>
                                                    <title lang="en">2</title>
                                                </meta>
                                            </param>
                                            <param name="one">
                                                <meta>
                                                    <title lang="en">1</title>
                                                </meta>
                                            </param>
                                        </param>
                                    </params>
                                </property>
                                <property name="highlightsItemSubline" type="text_line" colspan="4">
                                    <meta>
                                        <title lang="en">Subline</title>
                                    </meta>
                                </property>
                                <property name="highlightsItemBodytext" type="text_editor">
                                    <meta>
                                        <title lang="en">Bodytext</title>
                                    </meta>

                                    <params>
                                        <param name="table" value="false"/>
                                        <param name="link" value="true"/>
                                        <param name="ui_color" value="#ffcc00"/>
                                    </params>
                                </property>
                                <property name="highlightsItemUrl" type="url" colspan="6">
                                    <meta>
                                        <title>URL</title>
                                    </meta>
                                </property>
                                <property name="highlightsItemUrlText" type="text_line" colspan="6">
                                    <meta>
                                        <title lang="en">URL text</title>
                                    </meta>
                                </property>
                            </properties>
                        </type>
                    </types>
                </block>
            </properties>
        </section>
        <section name="location">
            <meta>
                <title lang="en">Location</title>
            </meta>
            <properties>
                <property name="locationBackgroundImage" type="media_selection" maxOccurs="1">
                    <meta>
                        <title lang="en">Background Image</title>
                    </meta>
                    <params>
                        <param name="types" value="image"/>
                    </params>
                </property>
                <property name="locationUrl" type="url" colspan="3">
                    <meta>
                        <title>Location URL</title>
                    </meta>
                </property>
                <property name="locationIframe" type="text_line" colspan="3">
                    <meta>
                        <title lang="en">Iframe</title>
                    </meta>
                </property>
                <property name="locationUrlText" type="text_line" colspan="3">
                    <meta>
                        <title lang="en">Location url text</title>
                    </meta>
                </property>
                <property name="locationGoogleMapsLink" type="url" colspan="3">
                    <meta>
                        <title>Google Maps Link</title>
                    </meta>
                </property>
                <property name="locationStreetAndNumber" type="text_line" colspan="6">
                    <meta>
                        <title lang="en">Street and number</title>
                    </meta>
                </property>
                <property name="locationZipAndTown" type="text_line" colspan="6">
                    <meta>
                        <title lang="en">Zip and town</title>
                    </meta>
                </property>
            </properties>
        </section>
        <section name="faq">
            <meta>
                <title lang="en">FAQ</title>
            </meta>
            <properties>
                <property name="faqInvisible" type="checkbox">
                    <meta>
                        <title lang="en">Invisible</title>
                    </meta>
                    <params>
                        <param name="type" value="toggler"/>
                        <param name="default_value" value="true"/>
                    </params>
                </property>
              <block name="faqItems" default-type="items" minOccurs="0">
                <meta>
                  <title>Items</title>
                </meta>
                <types>
                  <type name="items">
                    <meta>
                      <title>Item</title>
                    </meta>
                    <properties>
                      <property name="headline" type="text_line">
                        <meta>
                          <title>Frage</title>
                        </meta>
                        <params>
                          <param name="headline" value="true"/>
                        </params>
                      </property>
                      <property name="description" type="text_editor">
                        <meta>
                          <title>Description</title>
                        </meta>

                        <params>
                          <param name="table" value="false"/>
                          <param name="link" value="true"/>
                          <!-- CKEditor Parameters examples: -->
                          <param name="extra_allowed_content"
                                 value="img(*)[*]; span(*)[*]; div(*)[*]; iframe(*)[*]; script(*)[*]"/>
                          <param name="ui_color" value="#ffcc00"/>
                        </params>
                      </property>
                    </properties>
                  </type>
                </types>
              </block>
            </properties>
        </section>
    </properties>
</template>
