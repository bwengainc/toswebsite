<!-- News Section -->
<section class="news-section">
    <div class="auto-container">
        <div class="sec-title text-center">
            <div class="big-title">Ophthalmology</div>
            <div class="sub-title">City With Equity - Efficiency - Opportunity</div>
            <h2>News & Press Releases</h2>
        </div>
        
        <div class="row">
            <!-- Left Column: News Carousel -->
            <div class="col-lg-9 col-md-12">
                <div class="theme_carousel owl-theme owl-carousel" 
                     data-options='{"loop": true, "center": false, "margin": 30, "autoheight":true, "lazyload":true, "nav": true, "dots": true, "autoplay": true, "autoplayTimeout": 6000, "smartSpeed": 1000, "responsive":{ "0" :{ "items": 1 }, "600" :{ "items" : 1 }, "992" :{ "items" : 2 }, "1200":{ "items" : 3 }}}'>
                    
                    {% for news in content.newslist %}
                        {% if news.type != 'announcement' %}
                            {# Each slide MUST be a direct child of the carousel div #}
                            <div class="news-block">
                                <div class="inner-box">
                                    <div class="image">
                                        {#% if news.image %}
                                            {% set image = sulu_resolve_media(news.image.id, app.request.locale) %}
                                            <img src="{{ image.url }}" title="{{ news.title }}" alt="{{ news.title }}">
                                        {% endif %#}
                                        {% if news.image %} 
                                        {% set image = sulu_resolve_media(news.image.id, app.request.locale) %} 
                                        {% set source = image.formats['364x400'] 
                                        is defined and image.formats['364x400'] is not empty
                                         ? image.formats['364x400'] 
                                        : image.url %} 
                                        <img src="{{ source }}" title="{{ news.title }}" alt="{{ news.title }}"> 
                                        {% endif %}
                                        <div class="overlay">
                                            <div class="link-btn"><a href="{{ news.routePath }}"><i class="icon-arrow"></i></a></div>
                                        </div>
                                    </div>
                                    <div class="lower-content">
                                        <h4><a href="{{ news.routePath }}">{{ news.title }}</a></h4>
                                        <h3 style="font-size: 18px;">{{ news.subtitle }}</h3>
                                        <div class="text">{{ news.summary|raw }}</div>
                                        <ul class="post-meta">
                                            <li><i class="far fa-calendar"></i> {{ news.created|format_datetime('full', 'none', locale=app.request.getLocale()) }}</li>
                                        </ul>
                                        <p style="margin-top:9px;">
                                            <a class="btn btn-primary" href="{{ news.routePath }}" role="button">
                                                {{ "Read more..."|trans }} <i class="fa fa-angle-double-right"></i>
                                            </a>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>

            <!-- Right Column: Announcements Sidebar -->
            <div class="col-lg-3 col-md-12">
                <div class="sidebar-announcements" style="background: #f7f7f7; padding: 20px; border-radius: 8px;">
                    <h3 style="margin-bottom: 20px; border-bottom: 2px solid #eee; padding-bottom: 10px;">Announcements</h3>
                    {#% for news in content.newslist %#}
                    {% for news in content.newslist|filter(n => n.type == 'announcement')|slice(0,4) %}
                        {#% if news.type == 'announcement' %#}
                            <div class="featured-imagebox style2" style="margin-bottom: 20px;">
                                <div class="featured-content">
                                    <div class="post-meta" style="font-size: 12px; color: #777;">
                                        <i class="fa fa-calendar"></i> {{ news.created|format_datetime('short', 'none', locale=app.request.getLocale()) }}
                                    </div>
                                    <h4 style="font-size: 16px; margin-top: 5px;">
                                        <a href="{{ news.routePath }}">{{ news.title }}</a>
                                    </h4>
                                    <p style="font-size: 14px;">{{ news.subtitle }}</p>
                                </div>
                            </div>
                        {#% endif %#}
                    {% endfor %}

                    <div class="text-center" style="margin-top: 20px;">
                        <a class="theme-btn btn-style-one" href="{{ sulu_content_path('/announcement') }}">
                            <span>View All</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>











