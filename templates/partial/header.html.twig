<!--Mobile Navigation Toggler-->
<div class="mobile-nav-toggler"><img src="{{ asset('assets/images/icons/icon-bar.png')}}" alt=""></div>
                        

 <!-- Main Menu -->
{% set currentPath = app.request.pathinfo %}
<nav class="main-menu navbar-expand-md navbar-light">
  <div class="collapse navbar-collapse show clearfix" id="navbarSupportedContent">
    <ul class="navigation">
      {% for item in sulu_navigation_root_tree('main', 3) %}
        {% set itemUrl = sulu_content_path(item.url) %}
        {% set hasChildren = item.children|length > 0 %}
        {% set isActive = (currentPath == itemUrl) or (currentPath starts with itemUrl ~ '/') %}

        <li class="{% if hasChildren %}dropdown has-children{% endif %}{% if isActive %} active{% endif %}">
          <a href="{{ itemUrl }}">{{ item.title }}</a>

          {% if hasChildren %}
            <ul>
              {% for child in item.children %}
                {% set childUrl = sulu_content_path(child.url) %}
                {% set childHasChildren = child.children|length > 0 %}
                {% set childActive = (currentPath == childUrl) or (currentPath starts with childUrl ~ '/') %}

                <li class="dropdown{% if childHasChildren %} has-children{% endif %}{% if childActive %} active{% endif %}">
                  <a href="{{ childUrl }}">{{ child.title }}</a>

                  {% if childHasChildren %}
                    <ul>
                      {% for subChild in child.children %}
                        {% set subChildUrl = sulu_content_path(subChild.url) %}
                        {% set subChildActive = (currentPath == subChildUrl) or (currentPath starts with subChildUrl ~ '/') %}

                        <li{% if subChildActive %} class="active"{% endif %}>
                          <a href="{{ subChildUrl }}">{{ subChild.title }}</a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</nav>
