{% extends '@SuluForm/themes/basic.html.twig' %}

{# Add custom classes to <form> tag #}
{% block form_start %}
    {% set attr = attr|merge({ class: 'contact-form-box request_qoute_form wrap-form clearfix' }) %}
    {{ parent() }}
{% endblock %}

{# Remove row wrapper so each field stays full width #}
{% block form_widget_compound %}
    {% if form is rootform %}
        {% set attr = attr|merge({ class: '' }) %}
    {% endif %}
    {{ parent() }}
{% endblock %}

{# Customize text input fields #}
{% block form_widget_simple %}
    {% set type = type|default('text') %}
    <div class="form-group col-md-12">
        <input type="{{ type }}"
               {{ block('widget_attributes') }}
               class="form-control"
               placeholder="{{ attr.placeholder|default('') }}"
               value="{{ value }}">
    </div>
{% endblock %}

{# Customize textarea field #}
{% block textarea_widget %}
    <div class="form-group col-md-12">
        <textarea {{ block('widget_attributes') }}
                  rows="6"
                  class="form-control"
                  placeholder="{{ attr.placeholder|default('') }}">{{ value }}</textarea>
    </div>
{% endblock %}

{# Style submit button #}
{% block button_widget %}
    <div class="form-group col-md-12">
        <button type="{{ type|default('submit') }}"
                {{ block('button_attributes') }}
                class="theme-btn btn-style-one"
                data-loading-text="Please wait...">
            <span>{{ label|default('Send Message') }}</span>
        </button>
    </div>
{% endblock %}
