<properties xmlns="http://schemas.sulu.io/template/template"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xmlns:xi="http://www.w3.org/2001/XInclude"
            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    
    <block name="blocks" default-type="secretariat">
        <types>
            <type name="secretariat">
                <meta>
                    <title>Secretariat</title>
                </meta>
                <properties>
                    <property name="headline" type="text_line">
                        <meta>
                            <title>Headline</title>
                        </meta>
                    </property>
                    <property name="description" type="text_editor">
                        <meta>
                            <title>Beschreibung</title>
                        </meta>
                        <params>
                            <param name="link" value="true"/>
                        </params>
                    </property>
                    <property name="organisation" type="contact_account_selection">
                        <meta>
                            <title>Secretariat Selection</title>
                        </meta>
                    </property>
                </properties>
            </type>
        </types>
    </block>
</properties>
